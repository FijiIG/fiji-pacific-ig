       fhir:ImplementationGuide.definition.resource.name [ fhir:value "Pacific Hospital Example Fiji Divisional Hospital" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Example Pacific hospital organization in Fiji.\nIncludes organizational identifier, contact information, and address." ] ;
