       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Patient profile for South Pacific jurisdictions.\n\nIntegrates:\n- PacificHumanName\n- Patient-level clan affiliation\n- Guidance for usual vs official name use" ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]
