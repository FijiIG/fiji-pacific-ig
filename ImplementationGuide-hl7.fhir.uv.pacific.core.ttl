       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Profile of Allergy/Intolerance for Pacific Patient" ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]
